# Copy these into Vercel → Project → Settings → Environment Variables
# (or a local .env.local for development). All values are read server-side
# only, except the NEXT_PUBLIC_ ones, so secrets never reach the browser.

# ── Admin panel login ──────────────────────────────────────────────────
# Credentials for /admin. CHANGE THESE before going live. ADMIN_SESSION_SECRET
# can be any long random string; changing it logs everyone out.
ADMIN_EMAIL=admin@omgauriputra.com
ADMIN_PASSWORD=omgauri2024
ADMIN_SESSION_SECRET=please-change-this-to-a-long-random-string

# ── Database (Supabase) ────────────────────────────────────────────────
# Stores leads and orders so the admin panel shows real data from any
# device. Create a free project at supabase.com, run supabase/schema.sql in
# the SQL Editor, then copy these from Project Settings → API.
# The service-role key is secret — never expose it to the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# For product image uploads, also create a PUBLIC Storage bucket named
# "product-images" in Supabase → Storage.

# ── Payments (Razorpay) ────────────────────────────────────────────────
# Real card / UPI / netbanking payments at checkout. Without these, checkout
# places the order without taking an online payment (demo mode).
# Get the keys from https://dashboard.razorpay.com → Settings → API Keys.
# The Key Id is public; the Key Secret must stay server-side.
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── HubSpot CRM (contact + newsletter leads) ───────────────────────────
# 1. In HubSpot create a Form (Marketing → Forms) with fields:
#    First name, Last name, Email, Phone number, Message.
# 2. Copy the Portal ID (Settings → Account) and the Form GUID
#    (from the form's embed code / share URL).
HUBSPOT_PORTAL_ID=246494562
HUBSPOT_FORM_GUID=25e94130-48a1-4969-acd3-74db1bd5e557

# ── Instagram feed (homepage) ──────────────────────────────────────────
# A long-lived Instagram Graph API access token for the business account.
# Get it via Meta for Developers → Instagram Graph API / Basic Display.
INSTAGRAM_ACCESS_TOKEN=

# Public Instagram profile URL used by the "Follow on Instagram" button.
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/omgauriputra

# ── SEO ────────────────────────────────────────────────────────────────
# Your live site URL (used for canonical links, sitemap and robots). Set this
# to your custom domain once you have one, e.g. https://www.omgauriputra.com
NEXT_PUBLIC_SITE_URL=https://uraan-alpha.vercel.app
# Google Search Console verification code (the content="..." value from the
# "HTML tag" verification method).
NEXT_PUBLIC_GOOGLE_VERIFICATION=

# ── Business location (Footer, Contact, About, LocalBusiness schema) ──────
# Override any of these to relocate the store without touching component
# code. All are optional — sensible defaults are baked in.
NEXT_PUBLIC_BUSINESS_NAME=Om Gauri Putra
NEXT_PUBLIC_BUSINESS_ADDRESS_LINE1=A/69/1, Pocket C, Sector 24
NEXT_PUBLIC_BUSINESS_ADDRESS_LINE2=Budh Vihar, Phase 2
NEXT_PUBLIC_BUSINESS_CITY=New Delhi
NEXT_PUBLIC_BUSINESS_STATE=Delhi
NEXT_PUBLIC_BUSINESS_PINCODE=110086
NEXT_PUBLIC_BUSINESS_COUNTRY=India
NEXT_PUBLIC_BUSINESS_COUNTRY_CODE=IN

# ── Admin auth — Supabase Auth (Phase 2) ───────────────────────────────
# Public anon key + URL for Supabase Auth sign-in (safe in the browser; RLS
# protects the data). Get them from Supabase → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Email (Resend) — OTP codes + security alerts ───────────────────────
# Transactional email for 2FA email-OTP, new-device approval and login /
# location alerts. Create a key at https://resend.com → API Keys.
RESEND_API_KEY=
# Verified "from" address for security email (use a domain you control).
SECURITY_EMAIL_FROM="Om Gauri Putra Security <security@omgauriputra.com>"

# ── WhatsApp ───────────────────────────────────────────────────────────
# Public business number (digits only, with country code) used for all the
# wa.me "Chat on WhatsApp" buttons across the site and admin panel.
NEXT_PUBLIC_WHATSAPP_NUMBER=918851911653

# Where new-lead WhatsApp alerts are sent (digits only, international format).
# Defaults to NEXT_PUBLIC_WHATSAPP_NUMBER when unset. NOTE: delivery also needs
# WHATSAPP_TOKEN + WHATSAPP_PHONE_NUMBER_ID below to be set.
ADMIN_WHATSAPP_NUMBER=919128596443

# WhatsApp Business Cloud API (Meta) — lets the admin panel send messages
# (e.g. order updates) server-side and capture inbound chats as CRM leads.
# Create an app at developers.facebook.com → WhatsApp → API Setup.
#   WHATSAPP_TOKEN            permanent/long-lived access token
#   WHATSAPP_PHONE_NUMBER_ID  the Cloud API phone number id (not the number)
#   WHATSAPP_VERIFY_TOKEN     any secret string; used to verify the webhook
#                             at /api/whatsapp/webhook
#   WHATSAPP_APP_SECRET       the Meta app's secret (App Settings → Basic);
#                             verifies the X-Hub-Signature-256 header on each
#                             inbound webhook POST so forged messages can't
#                             become CRM leads. Optional but recommended.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# For new-lead alerts that must arrive OUTSIDE WhatsApp's 24-hour window, Meta
# requires a pre-approved template. In WhatsApp Manager create a template whose
# body has a single {{1}} placeholder (e.g. "New website lead 🔔 {{1}}"), then
# set its name + language here. Leave blank to fall back to plain text (which
# only delivers if the admin messaged the business number in the last 24h).
WHATSAPP_LEAD_TEMPLATE=
WHATSAPP_LEAD_TEMPLATE_LANG=en_US
# Number of {{n}} variables in that template (default 1). Set to 0 for a static
# template with no variables, or to test with Meta's built-in "hello_world".
WHATSAPP_LEAD_TEMPLATE_VARS=1
